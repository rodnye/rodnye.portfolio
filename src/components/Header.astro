---
import GrainBorderButton from "./GrainBorderButton.astro";
import HeaderLink from "./HeaderLink.astro";
---

<header>
  <nav
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-2xl bg-dark-500/60 border-b border-primary-700/8"
  >
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a
        href="#hero"
        class="font-jura font-bold text-lg tracking-wider text-primary-300 hover:text-primary-200 transition-colors flex items-center gap-2"
      >
        <span class="w-2 h-2 bg-primary-500 rounded-full inline-block"
        ></span>rodnye
      </a>
      <div class="hidden md:flex items-center gap-8">
        <HeaderLink>Sobre Mí</HeaderLink>
        <HeaderLink>Proyectos</HeaderLink>
        <HeaderLink>Skills</HeaderLink>
        <HeaderLink>Contacto</HeaderLink>
      </div>
      <GrainBorderButton href="https://github.com/rodnye">
        Github
      </GrainBorderButton>

      <button
        id="mobileMenuBtn"
        class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5"
      >
        <span class="w-5 h-px bg-primary-600 transition-all" id="ml1"></span>
        <span class="w-5 h-px bg-primary-600 transition-all" id="ml2"></span>
        <span class="w-3 h-px bg-primary-600 transition-all ml-auto" id="ml3"
        ></span>
      </button>
    </div>
    <div
      id="mobileMenu"
      class="md:hidden hidden border-t border-primary-700/8 bg-dark-500/95 backdrop-blur-2xl"
    >
      <div class="px-6 py-6 flex flex-col gap-4">
        <a
          href="#about"
          class="mobile-nav text-sm tracking-widest uppercase text-primary-500/60 hover:text-primary-300 transition-colors py-2"
          >Sobre mí</a
        >
        <a
          href="#projects"
          class="mobile-nav text-sm tracking-widest uppercase text-primary-500/60 hover:text-primary-300 transition-colors py-2"
          >Proyectos</a
        >
        <a
          href="#skills"
          class="mobile-nav text-sm tracking-widest uppercase text-primary-500/60 hover:text-primary-300 transition-colors py-2"
          >Skills</a
        >
        <a
          href="#contact"
          class="mobile-nav text-sm tracking-widest uppercase text-primary-500/60 hover:text-primary-300 transition-colors py-2"
          >Contacto</a
        >
      </div>
    </div>
  </nav>

  <!-- Margin in top -->
  <div class="mb-16"></div>
</header>
