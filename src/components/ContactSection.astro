---
import { Icon } from "astro-icon/components";
import {
  EMAIL,
  GITHUB_LINK,
  GOOGLE_LINK,
  LINKEDIN_LINK,
  TELEGRAM_LINK,
  X_LINK,
} from "../consts";

const socialIcons = [
  { name: "mdi:google", href: GOOGLE_LINK },
  { name: "mdi:telegram", href: TELEGRAM_LINK },
  { name: "mdi:github", href: GITHUB_LINK },
  { name: "mdi:linkedin", href: LINKEDIN_LINK },
  { name: "mdi:twitter", href: X_LINK },
  { name: "mdi:email-variant", href: `mailto:${EMAIL}` },
];
---

<div class="max-w-2xl mx-auto text-center px-4 sm:px-6">
  <span
    class="text-[9px] sm:text-[10px] tracking-[.35em] uppercase text-primary-700 block mb-4"
  >
    04 — Contact
  </span>
  <h2
    class="font-jura font-bold text-2xl sm:text-3xl md:text-5xl text-primary-200 tracking-tight mb-6"
  >
    Let's work <span class="text-primary-500">together</span>
  </h2>
  <p class="text-primary-500/40 leading-relaxed mb-10 sm:mb-14 max-w-md mx-auto text-sm sm:text-base">
    Do you have a project in mind? I'd love to hear your idea and explore how I can help you bring it to life.
  </p>
  
  <div class="space-y-3 max-w-sm mx-auto">
    <a
      href={GITHUB_LINK}
      target="_blank"
      rel="noopener"
      class="animated-border flex items-center gap-3 sm:gap-4 p-3 sm:p-4 border border-primary-700/10 bg-dark-200/30 rounded-xl justify-center hover:border-primary-700/20 transition-all duration-500 group"
    >
      <div
        class="w-8 h-8 sm:w-9 sm:h-9 shrink-0 rounded-lg bg-primary-900/15 border border-primary-700/10 flex items-center justify-center group-hover:bg-primary-900/25 transition-colors"
      >
        <Icon name="mdi:github" />
      </div>
      <span
        class="text-xs sm:text-sm tracking-wider text-primary-400 group-hover:text-primary-200 transition-colors break-all"
      >
        {GITHUB_LINK}
      </span>
      <Icon
        class="text-primary-800 group-hover:text-primary-600 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all shrink-0"
        name="mdi:open-in-new"
      />
    </a>
    
    <div
      id="emailContainer"
      class="animated-border flex items-center gap-3 sm:gap-4 p-3 sm:p-4 border border-primary-700/10 bg-dark-200/30 rounded-xl justify-center hover:border-primary-700/20 transition-all duration-500 cursor-pointer group"
      onclick="copyEmail()"
    >
      <div
        class="w-8 h-8 sm:w-9 sm:h-9 shrink-0 rounded-lg bg-primary-900/15 border border-primary-700/10 flex items-center justify-center group-hover:bg-primary-900/25 transition-colors"
      >
        <Icon name="mdi:email-outline" />
      </div>
      <span
        class="text-xs sm:text-sm tracking-wider text-primary-400 group-hover:text-primary-200 transition-colors break-all"
        id="emailText"
      >
        {EMAIL}
      </span>
      <Icon name="mdi:content-copy" class="shrink-0" />
    </div>
  </div>

  <div class="text-xl sm:text-3xl flex flex-wrap items-center justify-center gap-3 sm:gap-4 mt-10 sm:mt-14">
    {
      socialIcons.map(({ name, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener"
          class="w-9 h-9 sm:w-11 sm:h-11 flex items-center justify-center border border-primary-700/10 rounded-xl text-primary-700 hover:text-primary-300 hover:border-primary-500/30 hover:bg-primary-900/10 hover:scale-110 transition-all duration-300"
        >
          <Icon name={name} />
        </a>
      ))
    }
  </div>
</div>

<script>
  function copyEmail() {
    const emailText = document.getElementById("emailText");
    if (emailText) {
      navigator.clipboard.writeText(emailText.innerText).then(() => {
        const originalText = emailText.innerText;
        emailText.innerText = "Copied!";
        setTimeout(() => {
          emailText.innerText = originalText;
        }, 2000);
      });
    }
  }
</script>