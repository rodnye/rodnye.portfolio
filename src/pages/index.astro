---
import BaseHead from "../components/BaseHead.astro";
import DevPicture from "../components/DevPicture.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MeshBackground from "../components/MeshBackground.astro";
import OrbitsBackground from "../components/OrbitsBackground.astro";
import SkillMarquee from "../components/SkillMarquee.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .shimmer {
        background: linear-gradient(
          110deg,
          #6b581c 0%,
          #c9a84c 15%,
          #ffe080 35%,
          #c9a84c 55%,
          #6b581c 75%,
          #c9a84c 100%
        );
        background-size: 250% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmerMove 5s ease-in-out infinite;
      }
      @keyframes shimmerMove {
        0%,
        100% {
          background-position: 250% center;
        }
        50% {
          background-position: -50% center;
        }
      }

      .reveal {
        opacity: 0;
        transform: translateY(50px);
        transition:
          opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
          transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-d1 {
        transition-delay: 0.1s;
      }
      .reveal-d2 {
        transition-delay: 0.2s;
      }
      .reveal-d3 {
        transition-delay: 0.3s;
      }
      .reveal-d4 {
        transition-delay: 0.4s;
      }
      .reveal-d5 {
        transition-delay: 0.5s;
      }
      .reveal-d6 {
        transition-delay: 0.6s;
      }
      .reveal-d7 {
        transition-delay: 0.7s;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="relative">
      <div id="noise-bg"></div>
      <section
        id="hero"
        class="relative min-h-screen flex items-center flex-col justify-center px-6 overflow-hidden"
      >
        <MeshBackground />
        <OrbitsBackground/>

        <div class="relative z-10 max-w-4xl">
          <h1
            class="reveal reveal-d1 font-jura font-bold text-5xl leading-[.9] tracking-tighter mb-6"
          >
            <span
              class="block text-primary-300/30 font-light text-2xl sm:text-3xl md:text-4xl mb-2 tracking-widest"
            >
              Hola, soy
            </span>
            <span class="glitch shimmer" data-text="rodnye">Rodny Estrada</span>
          </h1>
          <div class="reveal reveal-d2 h-8 mb-8">
            <p
              class="text-primary-500/50 text-sm md:text-base font-quantico typing-cursor"
              id="typingText"
            >
            </p>
          </div>
          <div
            class="reveal reveal-d3 flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="#projects"
              class="magnetic-btn px-8 py-4 bg-linear-to-r from-primary-700 via-primary-600 to-primary-500 text-dark-900 font-jura font-semibold tracking-[.15em] text-sm rounded-lg transition-all duration-300 hover:shadow-[0_0_40px_rgba(201,168,76,0.25)] hover:scale-[1.02]"
            >
              <span class="btn-shine rounded-lg"></span>
              <span class="relative z-10 flex items-center gap-2"
                >Ver proyectos<span
                  class="iconify"
                  data-icon="mdi:arrow-down-right"
                  data-width="16"></span></span
              >
            </a>
            <a
              href="#contact"
              class="magnetic-btn px-8 py-4 border border-primary-700/20 text-primary-400 font-jura font-semibold tracking-[.15em] text-sm rounded-lg hover:border-primary-500/40 hover:text-primary-200 hover:bg-primary-900/5 transition-all duration-300"
            >
              <span class="btn-shine rounded-lg"></span><span
                class="relative z-10">Contactar</span
              >
            </a>
          </div>
        </div>
      </section>

      <DevPicture/>
      <SkillMarquee />
    </main>
    <Footer />
  </body>
</html>