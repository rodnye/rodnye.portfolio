---
import { Icon } from 'astro-icon/components';
import Divisor from '@/components/ui/Divisor.astro';
import BaseHead from '@/components/BaseHead.astro';
import ScrollProgress from '@/components/decor/ScrollProgress.astro';
import MeshBackground from '@/components/decor/MeshBackground.astro';
import OrbitsBackground from '@/components/decor/OrbitsBackground.astro';
import NoiseOverlay from '@/components/decor/NoiseOverlay.astro';

import SkillMarquee from './components/SkillMarquee.astro';
import TypingEffect from './components/TypingEffect.astro';
import HeaderSection from './sections/HeaderSection.astro';
import AboutStats from './sections/AboutStats.astro';
import ContactSection from './sections/ContactSection.astro';
import ProjectsSection from './sections/ProjectsSection.astro';

import { SITE_DESCRIPTION, SITE_TITLE } from '@/consts';
import '@/styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .terminal {
        background: rgba(8, 8, 8, 0.8);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(201, 168, 76, 0.1);
        border-radius: 12px;
        overflow: hidden;
      }
      .terminal-dots {
        display: flex;
        gap: 6px;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(201, 168, 76, 0.06);
      }
      .terminal-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }
    </style>
  </head>
  <body>
    <NoiseOverlay />
    <ScrollProgress />

    <HeaderSection />
    <main class="relative">
      <!-- Hero Section -->
      <section
        id="hero"
        class="relative flex flex-col items-center justify-center overflow-hidden px-6"
      >
        <MeshBackground />
        <OrbitsBackground />

        <div
          class="relative z-10 flex max-w-4xl flex-col md:self-start md:pl-12 lg:self-auto lg:pb-50"
        >
          <h1
            class="font-jura mt-20 mb-6 text-center text-5xl font-bold tracking-tighter md:text-left"
          >
            <span
              class="taos:translate-y-full taos:opacity-0 text-primary-300/30 mb-2 block text-2xl font-light tracking-widest duration-600 sm:text-3xl md:text-4xl"
            >
              Hi, I'm
            </span>
            <span class="taos:translate-y-80 taos:opacity-0 shimmer duration-800"
              >Rodny Estrada</span
            >
          </h1>

          <div class="mb-8 h-8">
            <TypingEffect />
          </div>

          <div class="mt-30 flex flex-col items-center justify-center gap-4 sm:flex-row md:mt-20">
            <a
              href="#projects"
              class="from-primary-700 via-primary-600 to-primary-500 text-dark-900 font-jura rounded-lg bg-linear-to-r px-8 py-4 text-sm font-semibold tracking-[.15em] transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_0_40px_rgba(201,168,76,0.25)]"
            >
              <span class="btn-shine rounded-lg"></span>
              <span class="relative z-10 flex items-center gap-2">
                View Projects
                <Icon name="mdi:arrow-down-right" />
              </span>
            </a>
            <a
              href="#contact"
              class="border-primary-700/20 text-primary-400 font-jura hover:border-primary-500/40 hover:text-primary-200 hover:bg-primary-900/5 rounded-lg border px-8 py-4 text-sm font-semibold tracking-[.15em] transition-all duration-300"
            >
              <span class="btn-shine rounded-lg"></span>
              <span class="relative z-10"> Contact Me </span>
            </a>
          </div>
        </div>
      </section>

      <section class="relative -z-5">
        <div class="absolute right-0 bottom-10 w-80 opacity-60 md:bottom-25 lg:w-120">
          <img src="/src/assets/dev.webp" />
        </div>
        <SkillMarquee />
      </section>

      <!-- About Section -->
      <section id="about" class="relative px-6 py-32">
        <div class="mx-auto max-w-6xl">
          <div class="grid items-start gap-16 lg:grid-cols-5">
            <div class="lg:col-span-3">
              <span
                class="reveal text-primary-700 mb-4 block text-[10px] tracking-[.35em] uppercase"
                >01 — About Me</span
              >
              <h2
                class="reveal reveal-d1 font-jura text-primary-200 mb-8 text-3xl leading-[1.1] font-bold tracking-tight md:text-5xl"
              >
                Building the<br /><span class="text-primary-500">digital future</span>
              </h2>
              <div class="reveal reveal-d2 terminal">
                <div class="terminal-dots">
                  <div class="terminal-dot bg-red-500/60"></div>
                  <div class="terminal-dot bg-yellow-500/60"></div>
                  <div class="terminal-dot bg-green-500/60"></div>
                  <span class="text-primary-800 ml-3 text-[10px] tracking-widest">about.md</span>
                </div>
                <div class="space-y-3 p-6 text-sm">
                  <p class="text-primary-600/70 leading-relaxed">
                    <span class="text-primary-500 font-bold">$</span> I'm a passionate developer focused
                    on creating software that makes an impact. My approach combines solid engineering
                    with attention to detail.
                  </p>
                  <p class="text-primary-600/70 leading-relaxed">
                    <span class="text-primary-500">$</span> I constantly explore new technologies to deliver
                    solutions that not only work, but inspire.
                  </p>
                  <p class="text-primary-600/70 leading-relaxed">
                    <span class="text-primary-500">$</span> Every project is an opportunity to learn,
                    iterate, and exceed expectations.
                  </p>
                  <p class="text-primary-500/40 typing-cursor pt-2">_</p>
                </div>
              </div>
            </div>
            <AboutStats />
          </div>
        </div>
      </section>
      <Divisor />

      <!-- Projects Section -->
      <section id="projects" class="relative px-6 py-32">
        <ProjectsSection />
      </section>
      <Divisor />

      <!-- Contact Section -->
      <section id="contact" class="relative px-6 py-32">
        <ContactSection />
      </section>
    </main>
  </body>
</html>
