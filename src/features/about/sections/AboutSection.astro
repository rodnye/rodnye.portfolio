---
import { Icon } from 'astro-icon/components';
---

<div class="mx-auto max-w-6xl">
  <div class="grid items-start gap-16 lg:grid-cols-5">
    <div class="lg:col-span-3">
      <span class="text-primary-700 mb-4 block text-sm tracking-[.35em] uppercase">
        01 — About Me
      </span>
      <h2
        class="font-jura text-primary-200 mb-8 text-3xl leading-[1.1] font-bold tracking-tight md:text-5xl"
      >
        Building the<br /><span class="text-primary-500">digital future</span>
      </h2>
      <div class="terminal">
        <div class="terminal-dots">
          <div class="terminal-dot bg-red-500/60"></div>
          <div class="terminal-dot bg-yellow-500/60"></div>
          <div class="terminal-dot bg-green-500/60"></div>
          <span class="text-primary-800 ml-3 text-sm tracking-widest">about.md</span>
        </div>
        <div class="space-y-3 p-6 text-sm">
          <p class="text-primary-600/70 leading-relaxed">
            <span class="text-primary-500 font-bold">$</span> I'm a passionate developer focused on creating
            software. My approach combines solid engineering with attention to detail.
          </p>
          <p class="text-primary-600/70 leading-relaxed">
            <span class="text-primary-500">$</span> I constantly explore new technologies to deliver solutions
            that not only work, but inspire.
          </p>
          <p class="text-primary-600/70 leading-relaxed">
            <span class="text-primary-500">$</span> Every project is an opportunity to learn, iterate,
            and exceed expectations.
          </p>
          <p class="text-primary-500/40 typing-cursor pt-2">_</p>
        </div>
      </div>
    </div>

    <!-- stats -->
    <div class="grid grid-cols-2 gap-3 lg:col-span-2">
      <div class="stat-card rounded-xl p-5">
        <div
          class="stat-number font-jura text-primary-300 mb-1 text-2xl font-bold md:text-3xl"
          id="statRepos"
        >
          0
        </div>
        <div class="text-primary-800 text-xs tracking-[.25em] uppercase">Repositories</div>
      </div>
      <div class="stat-card rounded-xl p-5">
        <div
          class="stat-number font-jura text-primary-300 mb-1 text-2xl font-bold md:text-3xl"
          id="statYears"
        >
          0
        </div>
        <div class="text-primary-800 text-xs tracking-[.25em] uppercase">Years coding</div>
      </div>
      <div class="stat-card col-span-2 flex items-center gap-4 rounded-xl p-6">
        <div
          class="bg-primary-900/20 border-primary-700/10 flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border"
        >
          <Icon class="text-primary-500 text-3xl" name="mdi:code-braces" />
        </div>
        <div>
          <div class="stat-number font-jura text-primary-300 text-2xl font-bold" id="statCommits">
            0
          </div>
          <div class="text-primary-800 text-xs tracking-[.25em] uppercase">
            Estimated contributions
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .terminal {
    background: rgba(8, 8, 8, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(201, 168, 76, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .terminal-dots {
    display: flex;
    gap: 6px;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(201, 168, 76, 0.06);
  }
  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .stat-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(201, 168, 76, 0.08);
    background: rgba(13, 13, 13, 0.5);
    backdrop-filter: blur(12px);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .stat-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #c9a84c, transparent);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .stat-card:hover {
    border-color: rgba(201, 168, 76, 0.2);
    transform: translateY(-2px);
  }
  .stat-card:hover::after {
    opacity: 0.6;
  }
</style>

<script>
  async function fetchGitHubStats() {
    try {
      const uR = await fetch('https://api.github.com/users/rodnye');

      if (!uR.ok) throw new Error();

      const user = await uR.json();
      const animateNumber = (id: string, target: number) => {
        const el = document.getElementById(id);
        if (!el) return;

        const duration = 1800;
        const start = performance.now();
        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          el.textContent = Math.round((1 - Math.pow(1 - p, 4)) * target).toLocaleString();
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      animateNumber('statRepos', user.public_repos);
      animateNumber('statYears', 5);
      animateNumber('statCommits', user.public_repos * 47);
    } catch (err) {
      console.warn('GitHub stats failed', err);
      document.getElementById('statYears')!.textContent = '5';
    }
  }
  fetchGitHubStats();
</script>
