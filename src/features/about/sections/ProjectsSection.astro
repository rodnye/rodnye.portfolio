---
import { GITHUB_LINK } from '@/consts';
import { Icon } from 'astro-icon/components';

const projects = [
  {
    name: 'FB Autopublisher',
    url: 'https://fb-autopublisher.italia.mdialityc.com/',
    description: 'Facebook autopublisher for spam oriented to sales managers',
    language: 'TypeScript',
    stars: null,
    forks: null,
    topics: ['facebook', 'automation', 'marketing'],
    date: 'Jan 2026',
    icon: 'mdi:robot',
    image: 'https://fb-autopublisher.italia.mdialityc.com/assets/original-logo_660-D-rstn3s.webp',
  },
  {
    name: 'cafe-ipv',
    url: 'https://github.com/rodnye/cafe-ipv',
    description: 'Android/Web app for product management, daily orders, and inventory table',
    language: 'Vue',
    stars: 3,
    forks: 0,
    topics: ['android', 'vite', 'vue3'],
    date: 'Apr 2026',
    icon: 'mdi:android',
    image: 'https://rodnye.github.io/cafe-ipv/assets/icon-logo-PZi9_iPw.png',
  },
  {
    name: 'literary-blog',
    url: 'https://github.com/rodnye/literary-blog',
    description: 'A custom Astro blog with GitHub branch persistence and Decap-CMS',
    language: 'Astro',
    stars: 6,
    forks: 0,
    topics: ['astro', 'blog', 'decap-cms'],
    date: 'Apr 2026',
    icon: 'mdi:book',
    image: 'https://github.com/rodnye/literary-blog/raw/master/docs/assets/logo_preview.webp',
  },
  {
    name: 'kodekloud.inspector',
    url: 'https://github.com/rodnye/kodekloud.inspector',
    description: 'Inspector for all KodeKloud courses compiled in Markdown',
    language: 'TypeScript',
    stars: 13,
    forks: 2,
    topics: [],
    date: 'Apr 2026',
    icon: 'mdi:robot',
    image:
      'https://mintcdn.com/kodekloud-c4ac6d9a/_u8CNiGuy79Fq3Fu/logo/dark.svg?fit=max&auto=format&n=_u8CNiGuy79Fq3Fu&q=85&s=14458e15af4945d2a9554c2d1d9af71d',
  },
  {
    name: 'codepicker',
    url: 'https://github.com/rodnye/codepicker',
    description:
      'Pick code into Markdown. Apply Markdown to code. Built for LLMs and quick backups.',
    language: 'TypeScript',
    stars: 8,
    forks: 0,
    topics: ['ai', 'cli', 'llm-tools', 'prompt-engineering'],
    date: 'May 2026',
    icon: 'mdi:toolbox',
    image: 'https://raw.githubusercontent.com/rodnye/codepicker/refs/heads/main/docs/logo.png',
  },
];

function getLangColor(lang: string): string {
  const colors: Record<string, string> = {
    JavaScript: '#F7DF1E',
    TypeScript: '#3178C6',
    Python: '#3776AB',
    HTML: '#E34F26',
    CSS: '#1572B6',
    Java: '#ED8B00',
    Go: '#00ADD8',
    Rust: '#CE422B',
    'C++': '#00599C',
    C: '#A8B9CC',
    Ruby: '#CC342D',
    Vue: '#4FC08D',
    Astro: '#FF5D01',
  };
  return colors[lang] || '#C9A84C';
}
---

<div class="mx-auto max-w-6xl">
  <div class="mb-16 text-center">
    <span class="reveal text-primary-700 mb-4 block text-sm tracking-[.35em] uppercase">
      02 — Projects
    </span>
    <h2
      class="reveal reveal-d1 font-jura text-primary-200 text-3xl font-bold tracking-tight md:text-5xl"
    >
      Selected <span class="text-primary-500">work</span>
    </h2>
  </div>

  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project, i) => {
        const lc = project.language ? getLangColor(project.language) : '';
        const delay = Math.min(i + 1, 7);
        return (
          <a
            href={project.url}
            target="_blank"
            rel="noopener"
            class="tilt-card reveal reveal-d{delay} group flex flex-col overflow-hidden rounded-xl"
          >
            <div class="card-spotlight" />

            {/* ── Imagen / Logo header ── */}
            <div class="card-image-zone relative z-10 flex items-center justify-center px-6 pt-6 pb-2">
              {project.image ? (
                <div class="card-image-frame">
                  <img
                    src={project.image}
                    alt={`${project.name} branding`}
                    class="card-image-src"
                    loading="lazy"
                    width="160"
                    height="80"
                  />
                </div>
              ) : (
                <div class="card-icon-fallback">
                  <Icon name={project.icon} class="text-primary-600/60" />
                </div>
              )}
            </div>

            {/* ── Cuerpo ── */}
            <div class="relative z-10 flex grow flex-col gap-4 px-6 pt-2 pb-6">
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-jura text-primary-200 truncate font-semibold">{project.name}</h3>
                <Icon
                  name="mdi:arrow-top-right"
                  class="text-primary-900 group-hover:text-primary-500 mt-0.5 shrink-0 transition-colors duration-300"
                />
              </div>
              <p class="text-primary-600/50 grow text-sm leading-relaxed">{project.description}</p>
              {project.topics.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {project.topics.map((topic) => (
                    <span class="text-primary-700/60 border-primary-700/[0.06] bg-primary-900/5 rounded border px-2 py-0.5 text-xs tracking-wider">
                      {topic}
                    </span>
                  ))}
                </div>
              )}
              <div class="text-primary-800 border-primary-700/[0.05] flex items-center gap-4 border-t pt-2 text-sm">
                {project.language ? (
                  <span class="flex items-center gap-1.5">
                    <span
                      class="h-2 w-2 rounded-full"
                      style={`background:${lc};box-shadow:0 0 4px ${lc}40`}
                    />
                    {project.language}
                  </span>
                ) : (
                  <span />
                )}
                {project.stars !== null && (
                  <span class="flex items-center gap-1">
                    <Icon name="mdi:star-four-points-outline" />
                    {project.stars}
                  </span>
                )}
                {project.forks !== null && (
                  <span class="flex items-center gap-1">
                    <Icon name="mdi:source-fork" />
                    {project.forks}
                  </span>
                )}
                {project.date && <span class="ml-auto opacity-50">{project.date}</span>}
              </div>
            </div>
          </a>
        );
      })
    }
  </div>

  <div class="mt-14 text-center">
    <a
      href={GITHUB_LINK + '?tab=repositories&type=source&sort=stargazers'}
      target="_blank"
      rel="noopener"
      class="text-primary-600 hover:text-primary-400 group border-primary-700/10 hover:border-primary-700/20 inline-flex items-center gap-2 rounded-lg border px-6 py-3 transition-colors"
    >
      <span class="btn-shine rounded-lg"></span>
      <span class="relative z-10 flex items-center gap-2">
        Show more
        <Icon
          class="transition-transform duration-300 group-hover:translate-x-1"
          name="mdi:arrow-right"
        />
      </span>
    </a>
  </div>
</div>

<script>
  function initTilt(card: HTMLElement) {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.transform = `perspective(800px) rotateX(${((y - rect.height / 2) / rect.height / 2) * -6}deg) rotateY(${((x - rect.width / 2) / rect.width / 2) * 6}deg) scale3d(1.02,1.02,1.02)`;
      card.style.setProperty('--mx', x + 'px');
      card.style.setProperty('--my', y + 'px');
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateX(0) rotateY(0) scale3d(1,1,1)';
    });
  }

  document.querySelectorAll('.tilt-card').forEach((card) => initTilt(card as HTMLElement));
</script>

<style is:global>
  .tilt-card {
    position: relative;
    border: 1px solid rgba(201, 168, 76, 0.08);
    background: rgba(13, 13, 13, 0.7);
    backdrop-filter: blur(16px);
    transition:
      border-color 0.5s,
      box-shadow 0.5s;
    transform-style: preserve-3d;
    perspective: 800px;
  }
  .tilt-card .card-spotlight {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
    background: radial-gradient(
      400px circle at var(--mx, 50%) var(--my, 50%),
      rgba(201, 168, 76, 0.06),
      transparent 60%
    );
  }
  .tilt-card:hover {
    border-color: rgba(201, 168, 76, 0.25);
    box-shadow: 0 25px 70px -15px rgba(201, 168, 76, 0.12);
  }
  .tilt-card:hover .card-spotlight {
    opacity: 1;
  }

  /* ── Zona de imagen ── */
  .card-image-zone {
    min-height: 100px;
    border-bottom: 1px solid rgba(201, 168, 76, 0.05);
  }

  .card-image-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    border-radius: 10px;
    background: rgba(201, 168, 76, 0.03);
    border: 1px solid rgba(201, 168, 76, 0.06);
    transition:
      border-color 0.4s,
      background 0.4s,
      transform 0.4s;
  }

  .tilt-card:hover .card-image-frame {
    border-color: rgba(201, 168, 76, 0.15);
    background: rgba(201, 168, 76, 0.06);
    transform: scale(1.03);
  }

  .card-image-src {
    height: 56px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: 0.7;
    filter: saturate(0.6) brightness(0.9);
    transition:
      opacity 0.4s,
      filter 0.4s;
  }

  .tilt-card:hover .card-image-src {
    opacity: 1;
    filter: saturate(1) brightness(1);
  }

  /* Fallback cuando no hay imagen */
  .card-icon-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(201, 168, 76, 0.04);
    border: 1px solid rgba(201, 168, 76, 0.07);
    transition:
      border-color 0.4s,
      background 0.4s,
      transform 0.4s;
  }

  .card-icon-fallback > svg {
    width: 24px;
    height: 24px;
  }

  .tilt-card:hover .card-icon-fallback {
    border-color: rgba(201, 168, 76, 0.18);
    background: rgba(201, 168, 76, 0.08);
    transform: scale(1.08);
  }
</style>
