---
import { Icon } from 'astro-icon/components';
import { EMAIL, GITHUB_LINK, GOOGLE_LINK, LINKEDIN_LINK, TELEGRAM_LINK, X_LINK } from '@/consts';

const socialIcons = [
  { name: 'mdi:google', href: GOOGLE_LINK },
  { name: 'mdi:telegram', href: TELEGRAM_LINK },
  { name: 'mdi:github', href: GITHUB_LINK },
  { name: 'mdi:linkedin', href: LINKEDIN_LINK },
  { name: 'mdi:twitter', href: X_LINK },
  { name: 'mdi:email-variant', href: `mailto:${EMAIL}` },
];
---

<div class="mx-auto max-w-2xl px-4 text-center sm:px-6">
  <span class="text-primary-700 mb-4 block text-xs tracking-[.35em] uppercase sm:text-sm">
    04 — Contact
  </span>
  <h2
    class="font-jura text-primary-200 mb-6 text-2xl font-bold tracking-tight sm:text-3xl md:text-5xl"
  >
    Let's work <span class="text-primary-500">together</span>
  </h2>
  <p
    class="text-primary-500/40 mx-auto mb-10 max-w-md text-sm leading-relaxed sm:mb-14 sm:text-base"
  >
    Do you have a project in mind? I'd love to hear your idea and explore how I can help you bring
    it to life.
  </p>

  <div class="mx-auto max-w-sm space-y-3">
    <a
      href={GITHUB_LINK}
      target="_blank"
      rel="noopener"
      class="animated-border border-primary-700/10 bg-dark-200/30 hover:border-primary-700/20 group flex items-center justify-center gap-3 rounded-xl border p-3 transition-all duration-500 sm:gap-4 sm:p-4"
    >
      <div
        class="bg-primary-900/15 border-primary-700/10 group-hover:bg-primary-900/25 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border transition-colors sm:h-9 sm:w-9"
      >
        <Icon name="mdi:github" />
      </div>
      <span
        class="text-primary-400 group-hover:text-primary-200 text-xs tracking-wider break-all transition-colors sm:text-sm"
      >
        {GITHUB_LINK}
      </span>
      <Icon
        class="text-primary-800 group-hover:text-primary-600 shrink-0 transition-all group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        name="mdi:open-in-new"
      />
    </a>

    <div
      id="emailContainer"
      class="animated-border border-primary-700/10 bg-dark-200/30 hover:border-primary-700/20 group flex cursor-pointer items-center justify-center gap-3 rounded-xl border p-3 transition-all duration-500 sm:gap-4 sm:p-4"
      onclick="copyEmail()"
    >
      <div
        class="bg-primary-900/15 border-primary-700/10 group-hover:bg-primary-900/25 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border transition-colors sm:h-9 sm:w-9"
      >
        <Icon name="mdi:email-outline" />
      </div>
      <span
        class="text-primary-400 group-hover:text-primary-200 text-xs tracking-wider break-all transition-colors sm:text-sm"
        id="emailText"
      >
        {EMAIL}
      </span>
      <Icon name="mdi:content-copy" class="shrink-0" />
    </div>
  </div>

  <div
    class="mt-10 flex flex-wrap items-center justify-center gap-3 text-xl sm:mt-14 sm:gap-4 sm:text-3xl"
  >
    {
      socialIcons.map(({ name, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener"
          class="border-primary-700/10 text-primary-700 hover:text-primary-300 hover:border-primary-500/30 hover:bg-primary-900/10 flex h-9 w-9 items-center justify-center rounded-xl border transition-all duration-300 hover:scale-110 sm:h-11 sm:w-11"
        >
          <Icon name={name} />
        </a>
      ))
    }
  </div>
</div>

<script>
  function copyEmail() {
    const emailText = document.getElementById('emailText');
    if (emailText) {
      navigator.clipboard.writeText(emailText.innerText).then(() => {
        const originalText = emailText.innerText;
        emailText.innerText = 'Copied!';
        setTimeout(() => {
          emailText.innerText = originalText;
        }, 2000);
      });
    }
  }
</script>
